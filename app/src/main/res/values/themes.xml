<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AstraNavi" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Transparent status bar for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- Transparent navigation bar for edge-to-edge -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Optional: set contrast for light/dark status bar icons -->
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
