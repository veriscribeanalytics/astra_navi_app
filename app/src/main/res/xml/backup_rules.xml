<?xml version="1.0" encoding="utf-8"?>
<!-- Intentionally unused: android:fullBackupContent="false" in the manifest disables
     D2D full-backup entirely. This file is kept as fallback documentation in case
     fullBackupContent is re-enabled later. data_extraction_rules.xml handles
     Android 12+ device-transfer exclusions separately. -->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="datastore/" />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
