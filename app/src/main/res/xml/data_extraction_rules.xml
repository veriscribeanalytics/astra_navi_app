<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude all shared preferences containing credentials or cache -->
        <exclude domain="sharedpref" path="." />
        <!-- Exclude all files (including DataStore preferences) -->
        <exclude domain="files" path="datastore/" />
        <exclude domain="files" path="." />
        <!-- Exclude database and database files -->
        <exclude domain="database" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude all credentials/cache during device-to-device transfer -->
        <exclude domain="sharedpref" path="." />
        <exclude domain="files" path="datastore/" />
        <exclude domain="files" path="." />
        <exclude domain="database" path="." />
    </device-transfer>
</data-extraction-rules>